# Supabase (optional)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Feature flags (optional, default true)
VITE_FEATURE_FLAGS_STORAGE_KEY=period-calendar:feature-flags
VITE_FEATURE_HISTORY_ENABLED_DEFAULT=true
VITE_FEATURE_PERIOD_LOG_ENABLED_DEFAULT=true
VITE_FEATURE_DAILY_LOG_ENABLED_DEFAULT=true
VITE_FEATURE_PROFILE_ENABLED_DEFAULT=true
VITE_FEATURE_ABOUT_ENABLED_DEFAULT=true
VITE_FEATURE_TERMS_AND_CONDITIONS_ENABLED_DEFAULT=true
VITE_FEATURE_COOKIES_POLICY_ENABLED_DEFAULT=true
VITE_FEATURE_PRIVACY_POLICY_ENABLED_DEFAULT=true
